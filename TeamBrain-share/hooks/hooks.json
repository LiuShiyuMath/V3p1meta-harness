{
  "SessionStart": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh",
          "timeout": 90
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/query-teambrain-share.sh",
          "timeout": 30
        },
        {
          "type": "command",
          "command": "bash /Users/m1/projects/V3p1meta-harness/TeamBrain-share/scripts/eng-gate-inject.sh",
          "timeout": 15
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "bash /Users/m1/.claude/scripts/hooks/laziness-self-report.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash /Users/m1/projects/V3p1meta-harness/TeamBrain-share/scripts/eng-gate-exam.sh",
          "timeout": 15
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Edit|Write|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/gateguard-fact-force.js",
          "timeout": 5
        }
      ]
    }
  ]
}
